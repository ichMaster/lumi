# Lumi secrets — copy to `.env` (gitignored) and fill in. Never commit real keys.

# v0.1 — Anthropic Claude Haiku (the only model to start).
ANTHROPIC_API_KEY=

# Optional config overrides (defaults live in core/config.py).
# LUMI_MODEL=claude-haiku-4-5-20251001   # e.g. claude-sonnet-4-6, claude-opus-4-8
# LUMI_PROVIDER=anthropic
# LUMI_CANON_PATH=core/canon/lili.md
# LUMI_STYLES_PATH=core/styles.md         # answer-style overlays (/style short|explain|emotional)
# LUMI_MEMORY_WINDOW=40                  # verbatim message window (older msgs are compacted)
# LUMI_COMPACTION_BATCH=20               # fold older messages into a digest in batches of this size
# LUMI_MAX_TOKENS=4096
# LUMI_THINKING=off                      # adaptive extended thinking: on / off (Opus 4.8, Sonnet 4.6)
# LUMI_EFFORT=                           # thinking depth: low | medium | high | xhigh | max (Opus xhigh/max)
