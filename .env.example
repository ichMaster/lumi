# Lumi secrets — copy to `.env` (gitignored) and fill in. Never commit real keys.

# v0.1 — Anthropic Claude (the default provider).
ANTHROPIC_API_KEY=

# v0.18 — other providers behind the same LLMClient seam (set LUMI_PROVIDER above; only the
# active provider's key is needed). thinking/effort/prompt-cache are Anthropic-only and ignored elsewhere.
# OPENAI_API_KEY=                         # LUMI_PROVIDER=openai (SECRET)
# DEEPSEEK_API_KEY=                       # LUMI_PROVIDER=deepseek (SECRET)
# MINIMAX_API_KEY=                        # LUMI_PROVIDER=minimax (SECRET)
# LUMI_LLM_BASE_URL=http://localhost:11434/v1   # LUMI_PROVIDER=local (Ollama / LM Studio); overrides base_url

# Optional config overrides (defaults live in core/config.py).
# LUMI_MODEL=claude-haiku-4-5-20251001   # any Claude tier: claude-sonnet-4-6, claude-opus-4-8, …
# LUMI_PROVIDER=anthropic                 # v0.18: anthropic | openai | deepseek | minimax | local
#                                         # only the active provider's key is required (see below)
# LUMI_CANON_PATH=core/canon/lili.md
# LUMI_STYLES_PATH=core/styles.md         # answer styles — 16 base + 6 meta-styles (/style лагідна | /style коротко офіційно)
# LUMI_MEMORY_WINDOW=40                  # verbatim message window (older msgs are compacted)
# LUMI_COMPACTION_BATCH=20               # fold older messages into a digest in batches of this size
# Short-memory recall (v0.11) — 3 date-based layers (cumulative): sessions → days → weeks.
# LUMI_SESSION_DAYS=2                    # tier 1: every session summary from the last N days, in DETAIL
# LUMI_DAY_DAYS=7                        # tier 2: per-day digest for the last N days
# LUMI_WEEK_DAYS=14                      # tier 3: per Mon–Sun week digest for the last N days
# LUMI_MAX_DAY_ROWS=4                    # rows in each day's consolidated digest
# LUMI_MAX_WEEK_ROWS=6                   # rows in each week's consolidated digest
# Long-term facts digest — consolidate accumulated facts into a compact prompt view (one model
# call, rebuilt only when facts grow; raw facts kept). Big token saver once facts pile up.
# LUMI_FACTS_DIGEST=on                   # on / off — inject the consolidated digest instead of all raw facts
# LUMI_FACTS_DIGEST_MAX=150              # target lines for the digest (kicks in once facts exceed this)
# v0.15 prompt caching — mark the stable prompt prefix (canon + instructions + memory + facts-digest
# + mood) as an Anthropic cache breakpoint; warm turns pay ~10% for it. On by default; same text.
# LUMI_PROMPT_CACHE=on                   # on / off — pass the cache_prefix to the model on the reply turn
# Token-usage report — on each session close, append usage to .lumi/usage-ledger.jsonl and re-render
# .lumi/usage-report.md (estimated cost by month / week / day / session). On by default.
# LUMI_USAGE_REPORT=on                   # on / off
# Per-call cache & cost monitor — on each session close, render .lumi/cache-report.md: cache behaviour
# (reads/writes by channel + why each write happened) AND cost (by session × activity × operation —
# input/output/cache-read/cache-write — with share, per session + accumulated). One unified report.
# LUMI_CACHE_MONITOR=off                 # on / off (a per-call JSONL log + the report; off by default)
# v0.19 read + v0.20 write + v0.29 metadata/folder/copy — Лілі can list/search/read/stat files AND
# create/append/copy files + make folders in a PER-USER SANDBOX during a turn, via a bounded tool-loop.
# OFF by default. File content is UNTRUSTED data (never instructions); paths are sandboxed (no ../,
# absolute, or symlink escape). Writes are NON-DESTRUCTIVE: create_file/create_folder are new-only,
# append_file is end-only, copy_file's dest is new-only — no overwrite, no delete, no move. Anthropic provider only.
# LUMI_FILE_TOOL=off                     # on / off — enable the file tools (read + write)
# LUMI_FILES_DIR=.lumi/files             # sandbox root (per-user subdirs: .lumi/files/<user_id>/)
# LUMI_FILE_READ_LINES=200               # default / max lines per read_file call
# LUMI_FILE_READ_MAX_TOTAL=2000          # max total lines one turn may read across all read_file calls
# LUMI_FILE_FIND_MAX=50                  # max matches find_in_file returns
# LUMI_FILE_WRITE_MAX=65536              # max bytes of one create_file/append_file write (v0.20)
# LUMI_FILE_COPY_MAX=5242880             # max source bytes for one copy_file (v0.29; copies existing bytes — separate from WRITE_MAX)
# LUMI_TOOL_MAX_STEPS=8                  # max tool calls per turn (loop cap)
# LUMI_FILE_TOOL_TRACE=off               # show the file tools used each turn (TUI trace + .lumi/tool-log.jsonl)

# v0.21 Wikipedia tool — Лілі can look something up on Wikipedia during a turn (wiki_search → wiki_read),
# on the same bounded tool-loop. OFF by default. Returned text is UNTRUSTED data (never instructions);
# the query is built ONLY from your request (no relationship memory / personal data is sent). Free REST
# API, no key. Works on any model (function-calling). See docs/WIKI_SETUP.md.
# LUMI_WIKI=off                          # on / off — enable the Wikipedia tool
# LUMI_WIKI_LANG=uk,en                   # language edition(s), comma-separated; first with a hit wins
# LUMI_WIKI_BASE_URL=                    # override the host (default https://{lang}.wikipedia.org)
# LUMI_WIKI_MAX_CHARS=1500               # extract size cap for one wiki_read
# LUMI_WIKI_MAX_CALLS=4                  # max wiki calls per turn
# v0.25 news tool — Лілі reads fresh news on demand during a turn (news_search → news_read), on the same
# bounded loop, from ONE outlet: The Guardian Open Platform. OFF by default; needs a free Guardian key.
# Bodies are UNTRUSTED data (never instructions); the query goes out ENGLISH and ONLY the topic (no
# personal data); the reply comes back Ukrainian, cited. DISTINCT from the v0.4 ambient news below
# (LUMI_NEWS_URL/_CAP) — different namespace, different purpose. See docs/NEWS_SETUP.md.
# LUMI_NEWS_TOOL=off                     # on / off — enable the news tool
# LUMI_NEWS_API_KEY=                     # Guardian developer key (open-platform.theguardian.com)
# LUMI_NEWS_API_URL=https://content.guardianapis.com   # API base (override for a mirror/tests)
# LUMI_NEWS_SECTIONS=world,politics,business,technology,science,environment,culture,sport  # topic allowlist
# LUMI_NEWS_MAX_RESULTS=8                # candidates per news_search
# LUMI_NEWS_MAX_CHARS=3000               # body size cap for one news_read
# LUMI_NEWS_MAX_CALLS=4                  # max news calls per turn
# LUMI_NEWS_DAYS=7                       # default recency window for a search (from-date)

# v0.27 web lookup — Лілі pulls a FRESH, grounded answer from the live internet during a turn
# (web_lookup), on the same bounded loop, via Gemini + Google Search grounding (the "AI Overview"). For
# "what's happening / coming up" that Wikipedia (timeless) and Guardian (one outlet) can't cover. Also a
# /web <query> command (aliases /search, /w). OFF by default; PAID — reuses GEMINI_API_KEY (the same key
# image generation uses; no new key). The answer is UNTRUSTED data (never instructions); the query goes
# out ENGLISH and ONLY the topic (no personal data); the reply comes back Ukrainian, answer-first, honest
# it's looked-up; the prompt is date-anchored to today. See docs/WEB_LOOKUP_SETUP.md.
# LUMI_WEB_LOOKUP=off                    # on / off — enable the web lookup tool (+ /web command)
# LUMI_WEB_LOOKUP_MODEL=gemini-2.5-flash # the Gemini grounding model
# LUMI_WEB_LOOKUP_MAX_CALLS=2            # max grounded calls per turn (PAID — keep small)
# LUMI_WEB_LOOKUP_MAX_CHARS=2000         # cap on the answer length folded into the reply
# (GEMINI_API_KEY is set in the image section below / above — the same key.)

# v0.28 journal tool — Лілі keeps a personal literary diary: she writes a SUMMARY OF THE DAY in her own
# voice (journal_write) and rereads previous days by date (journal_read / journal_list), on the same
# bounded loop. LOCAL — no network, no key. She decides the prose; CODE auto-stamps each entry with the
# day's mood (v0.6) + biorhythms (v0.8) + astrology forecast (the v0.6 reading), so it matches /mood +
# /biorhythm. NON-DESTRUCTIVE (create-only/append-only). LUMI_JOURNAL_DIR is a DEDICATED root (per-user
# subdirs), OUTSIDE the file-tool sandbox — so the raw file tools can never reach/modify her diary. Also a
# /journal [date|list|write] command. OFF by default. See docs/JOURNAL_SETUP.md.
# LUMI_JOURNAL=off                       # on / off — enable the journal tools (+ /journal command)
# LUMI_JOURNAL_DIR=.lumi/journal         # dedicated journal root; entries at .lumi/journal/<user>/<date>.md
# LUMI_JOURNAL_MAX_CHARS=4000            # cap on a single journal_write body

# v0.22 local image tool I: vision — Лілі can SEE images and describe them. Share one with /image <path>
# (a multimodal block on your turn), or she views a sandbox image via the view_image tool. OFF by default.
# An image is UNTRUSTED data (text inside it is never a command); sandboxed + per-user; needs the
# Anthropic provider (multimodal). A shared image is sent to the model provider (Anthropic). See
# docs/IMAGE_SETUP.md. Generation (text → PNG) is v0.23.
# LUMI_IMAGE=off                         # on / off — enable vision (view_image + /image shared input)
# LUMI_VISION_MAX=4                      # max images viewed/attached per turn
# LUMI_IMAGE_MAX_BYTES=5242880           # max size of one viewed image (≈5 MB)
# v0.23 image generation — generate_image (text → PNG), saved CREATE-ONLY into her sandbox + shown.
# Rides LUMI_IMAGE (above). PAID — needs GEMINI_API_KEY (the faces-skill key). The prompt carries NO
# personal data; provider content-safety applies. Display reuses the v0.7 viewer + v0.13 Telegram photo.
# LUMI_IMAGE_PROVIDER=gemini             # generation backend
# LUMI_IMAGE_MODEL=gemini-2.5-flash-image  # generation model (Nano Banana)
# LUMI_IMAGE_SIZE=768                    # generated PNG size hint
# LUMI_IMAGE_MAX_GEN=2                   # max generations per turn (paid)
# LUMI_IMAGE_SHOW=path,viewer,telegram   # where to show a generated PNG (path always; the "telegram"
#                                          target is superseded by v0.24 send_image — see below)
# v0.24 image tool III: send to Telegram — the send_image tool lets Лілі CHOOSE to send a sandbox
# picture (generated or dropped-in) to your Telegram. Rides LUMI_IMAGE (above) AND needs the Telegram
# bridge connected (LUMI_BRIDGE=on + the TUI running); bridge off → "Telegram not connected". The owner
# is the recipient. No extra env — it reuses LUMI_IMAGE + the LUMI_TELEGRAM_* bridge. See
# docs/IMAGE_SETUP.md (and docs/TELEGRAM_SETUP.md). This replaces the old auto-push of every generated
# PNG (LUMI_IMAGE_SHOW=telegram) — now she decides which picture is worth sending.
# v0.16 Semantic recall (RAG) — embed every message into a per-user vector store and search it by
# meaning (/recall <query>). OFF by default. The default embedder is LOCAL (private — text never
# leaves the machine, no per-call cost); needs the extra: uv sync --extra embed. A cloud embedder
# (voyage/openai) sends text out, so it's only used when you set its key. Per-user, isolated.
# LUMI_RECALL=off                        # on / off — the whole feature (index + /recall)
# LUMI_EMBED_PROVIDER=local              # local (private, default) | voyage | openai
# LUMI_EMBED_MODEL=intfloat/multilingual-e5-large  # multilingual (a fastembed model)
# VOYAGE_API_KEY=...                     # only for LUMI_EMBED_PROVIDER=voyage (SECRET)
# OPENAI_API_KEY=...                     # only for LUMI_EMBED_PROVIDER=openai (SECRET)
# LUMI_RECALL_K=5                        # /recall: how many matches to return
# LUMI_EMBED_MAX_CHARS=2000              # cap per message before embedding (local model ~512 tok; Voyage ~32k → raise it)
# v0.17 Automatic RAG — pull the query-relevant past into EVERY reply (not just /recall). Needs
# LUMI_RECALL=on (the index). OFF by default. Each hit arrives with its session neighbours (a dated
# dialogue snippet), deduped against the live window, behind a relevance floor + a char budget.
# LUMI_RAG=off                           # on / off — inject «Релевантні моменти минулого» each turn
# LUMI_RAG_K=4                           # top-K relevant moments injected per turn
# LUMI_RAG_FLOOR=0.3                      # cosine relevance floor — weaker matches aren't injected
# LUMI_RAG_W=2                           # context window: ±W neighbour messages around each hit
# LUMI_RAG_MAX_CHARS=1200                # the recall block's total char budget
# LUMI_RAG_SNIPPET_CHARS=240             # per-line cap for each recalled moment (longer → more context, more tokens)
# v0.31 recall tool — let Лілі search her OWN memory on demand mid-turn (a targeted query ≠ the message,
# multi-hop) on the v0.19 tool-loop: the "pull" that complements the auto-RAG "push". Needs LUMI_RECALL=on
# + an embedder; the result is her own recollection (TRUSTED, not untrusted), deduped vs what's already in
# the prompt. OFF by default → identical to v0.17. See docs/RECALL_TOOL_SETUP.md.
# LUMI_RECALL_TOOL=off                   # on / off — offer the model-callable recall() tool
# LUMI_RECALL_TOOL_K=5                   # how many past moments a recall() call returns
# LUMI_RECALL_TOOL_MAX_CALLS=3           # per-turn cap on recall() calls (bounds multi-hop search)
# LUMI_MAX_TOKENS=4096
# LUMI_THINKING=off                      # adaptive extended thinking: on / off (Opus 4.8, Sonnet 4.6)
# LUMI_EFFORT=                           # thinking depth: low | medium | high | xhigh | max (Opus xhigh/max)

# v0.4 ambient context (now/here) — all OFF unless set; degrade gracefully.
# LUMI_LOCATION=Львів                    # a place name shown to Лілі (no HTTP)
# LUMI_LAT=49.84                         # latitude  — with LUMI_LON enables weather (no key)
# LUMI_LON=24.03                         # longitude
# LUMI_WEATHER_URL=https://api.open-meteo.com/v1/forecast?latitude={lat}&longitude={lon}&current=temperature_2m,apparent_temperature,weather_code&daily=temperature_2m_max,temperature_2m_min,weather_code&forecast_days=1&timezone=auto  # {lat}/{lon} substituted; Open-Meteo JSON
# LUMI_NEWS_URL=                         # an RSS/Atom feed URL — a few headlines (no key)
# LUMI_NEWS_CAP=3                        # max headlines

# v0.4 idle nudge — Лілі speaks first after a silence (you never see the nudge). OFF by default.
# LUMI_IDLE_NUDGE=off                    # on / off
# LUMI_IDLE_SECONDS=240                  # silence before a nudge (~4 min)
# LUMI_NUDGE_PATH=core/nudges.md         # the v0.4 nudge openers (plain lines, fired verbatim)
# LUMI_QUIET_HOURS=23-7                  # the NUDGE's quiet window (wraps midnight)
# The v0.12 proactive-think SEEDS + its OWN quiet window live separately:
# LUMI_THINK_SEEDS_PATH=core/think_seeds.md   # the proactive-think seed menu (%think {topic} lines)
# LUMI_THOUGHTS_QUIET_HOURS=23-7         # the think's quiet window — independent of LUMI_QUIET_HOURS;
#                                        # unset = inherit the nudge's; "off" = the think is never quiet

# v0.5 emoji — Лілі's emotion shown as an emoji next to her reply. Editable map.
# LUMI_EMOJI_PATH=core/emoji.md          # emotion→emoji+intensity table (add/remove/change)

# v0.6 mood of the day + v0.8 biorhythms — her daily temperament. The model writes a
# horoscope-flavoured reading from core/natal.md; v0.8 blends in three COMPUTED biorhythm
# cycles. Both ON by default; only the resolution colors tone/emotion, never competence.
# /mood shows the blended resolution · /biorhythm shows the raw cycles.
# LUMI_MOOD=on                           # on / off — the whole daily mood
# LUMI_BIORHYTHMS=on                     # on / off — the biorhythm layer (off → mood horoscope-only)
# LUMI_CYCLE=on                          # on / off — her hormonal cycle (menstruation/ovulation/PMS → mood)
# LUMI_NATAL_PATH=core/natal.md          # natal chart (+ "Народження: …" → biorhythms; "Цикл: …" → cycle)
# Closeness — the per-user relationship level (v0.10). Biases warmth/openness, never competence.
# LUMI_CLOSENESS=on                       # on / off — the whole closeness feature (read + level block)
# LUMI_CLOSENESS_PATH=core/closeness.md   # authored 5 levels (Ввічлива → Найрідніша)
# LUMI_CLOSENESS_BASELINE=30              # resting value (0–100) silence decays toward
# LUMI_CLOSENESS_DECAY=0.9                # gap-to-baseline kept per day of silence (lower = forgets faster)
# LUMI_CLOSENESS_W_POS=1.0                # weight per positive dim (warmth/vulnerability/playful)
# LUMI_CLOSENESS_W_NEG=1.5                # weight per negative dim (harm/manipulation)
# LUMI_CLOSENESS_DELTA=5.0                # value points per unit of relational signal (higher = moves faster)
# LUMI_CLOSENESS_INERTIA=3.0              # dead-zone around a level edge (higher = stickier levels)
# LUMI_CLOSENESS_DRIFT=0.1                # per-turn pull toward the baseline (so an active warm streak can't pin at max)
# The EFFECTIVE level injected each turn = base + an ephemeral mood-shift (±1 level band) from her
# emotional biorhythm + cycle phase (warmth/openness only, never competence) — not persisted.
# LUMI_CLOSENESS_MOOD_SHIFT=1.0           # strength of that daily shift: 0..1 (1=full ±1 band, 0.5=half, off/0=disabled)

# v0.12 thought-stream — her mind acts on its own (%think/%wonder) into a global dated diary;
# the last N hours feed back into the prompt; a fraction graduate to a spoken turn. ON by default.
# LUMI_THOUGHTS=on                        # on / off — the whole thought-stream
# LUMI_THOUGHTS_WINDOW_H=24               # prompt feedback window: thoughts from the last N hours
# LUMI_THOUGHTS_MAX_LINES=12              # max thought lines injected into the prompt (the hard cap)
# LUMI_THOUGHTS_INTERVAL_S=600            # idle seconds before a proactive %think
# LUMI_THOUGHTS_CAP=6                     # max proactive thinks per session (restraint)
# LUMI_THOUGHTS_SPOKEN_RATIO=0.2          # fraction of thinks that graduate to a spoken turn
# LUMI_THOUGHTS_SHOW=hidden               # /thoughts policy: hidden / admin / off
# LUMI_THOUGHTS_CONTEXT=lean              # thought prompt: lean (seeds, cheap) / full (whole reply backdrop)

# v0.7.x TUI sound — a short blip on send + receive (never on the idle nudge). OFF by
# default; toggle at runtime with Ctrl+S (the status line shows sound:on/off).
# LUMI_SOUND=off                         # on / off — start with sound on

# v0.7 emotion-face viewer — the core writes the current emotion here; ./lumi-viewer polls it.
# LUMI_FACE_SIGNAL=.lumi/face.txt        # one-word signal file (default: next to the store)
# LUMI_FACE_IDLE_SECONDS=120             # relax the face to calm after this idle (0 = off)

# v0.13 Telegram bridge — the TUI is the brain; two daemons shuttle a file bus.
# Turn the TUI side on (reads inbox, writes outbox); then run the two daemons.
# LUMI_BRIDGE=on                          # off by default; on = the TUI participates in the bus
# LUMI_INBOX_PATH=.lumi/inbox.jsonl       # Telegram → file (the TUI consumes)
# LUMI_OUTBOX_PATH=.lumi/outbox.jsonl     # Лілі's replies → file (daemon 2 sends)
# LUMI_TELEGRAM_TOKEN=123:ABC...          # the bot token (SECRET — never commit; this is .env, gitignored)
# LUMI_TELEGRAM_ALLOWLIST=11111111        # your Telegram id(s), comma-separated (only these are served)
# LUMI_TELEGRAM_FLUSH_S=2                  # daemon 1: consolidate a burst, flush every N seconds
# LUMI_TELEGRAM_BATCH=5                    # daemon 2: max replies merged per Telegram message (bounds a backlog)
# LUMI_TELEGRAM_CATCHUP_H=24              # daemon 2: skip replies older than this on restart (no flood)
# LUMI_TELEGRAM_PHOTO=0                   # daemon 2: probability 0..1 of attaching the face photo (0.2 ≈ 1/5; on/off = 1/0)
# LUMI_TELEGRAM_VOICE=off                # daemon 2: send replies as VOICE messages (needs the LUMI_VOICE_* key/id + ffmpeg)
# LUMI_TELEGRAM_STT=off                  # daemon 1: TRANSCRIBE inbound Telegram VOICE messages (reuses LUMI_STT_* / the v0.26 adapter)

# v0.14 Local voice (ElevenLabs) — a separate process voices Лілі's replies aloud.
# Turn the TUI side on (writes the outbox, like the bridge); then run the voicer:
#   uv run --extra voice python -m voice.voicer
# It voices ONLY Лілі's replies (your keyboard/Telegram lines are skipped) and skips the backlog
# on first run. The token is a SECRET (this is .env, gitignored — never commit it).
# LUMI_VOICE=on                           # off by default; on = the TUI writes the outbox for the voicer
# ELEVENLABS_API_KEY=sk_...               # the ElevenLabs key (SECRET)
# LUMI_VOICE_ID=...                       # the ElevenLabs voice id to speak in
# LUMI_VOICE_MODEL=eleven_multilingual_v2 # model (multilingual handles Ukrainian)
# LUMI_VOICE_SKIP_MISSED=off              # on = on EVERY start skip replies missed while it was off
# v0.26 Local dictation (STT) — the MIRROR of the voicer: a separate process hears your speech and types
# it into the chat. Turn the TUI side on (it drains the inbox + adds a Ctrl+D listen toggle); then run:
#   uv run --extra dictation python -m voice.dictator
# Press Ctrl+D to start/stop listening; speak Ukrainian; your recognized line drives a turn like typing.
# Provider: deepgram (Nova-3 uk, needs DEEPGRAM_API_KEY) / elevenlabs (Scribe, ELEVENLABS_API_KEY) /
# whisper (OFFLINE, no key). See docs/DICTATION_SETUP.md.
# LUMI_DICTATION=off                       # off by default; on = the TUI drains inbox + the listen toggle
# LUMI_STT_PROVIDER=deepgram               # deepgram / elevenlabs / whisper (offline)
# LUMI_STT_MODEL=                          # override the STT model ("" → provider default; deepgram: nova-3 / nova-2)
# LUMI_STT_LANG=uk                         # recognition language
# DEEPGRAM_API_KEY=...                     # the Deepgram key (SECRET) — Whisper needs none
# LUMI_LISTEN_FLAG=.lumi/listen.flag       # the on/off signal the TUI writes + the dictator reads
